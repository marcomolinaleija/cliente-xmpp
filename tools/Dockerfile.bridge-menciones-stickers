# syntax=docker/dockerfile:1.7

ARG BASE_IMAGE=ghcr.io/marcomolinaleija/cliente-xmpp-bridge:v1
FROM ${BASE_IMAGE}

USER root
RUN --mount=type=bind,from=ghcr.io/astral-sh/uv:python3.13-trixie-slim@sha256:08477888ac23d6cfbeb8c7dc6fc70cf297fd38b7bf35522be33ce832750ca242,source=/usr/local/bin/uv,target=/usr/local/bin/uv \
    /usr/local/bin/uv pip install --python /venv/bin/python --no-cache --no-deps \
    "rlottie-python==1.3.8"
COPY tools/patch_slidge_whatsapp_mentions.py /tmp/patch_slidge_mentions.py
RUN python -B /tmp/patch_slidge_mentions.py /venv/lib/python3.13/site-packages --no-backup && \
    rm /tmp/patch_slidge_mentions.py
USER slidge
