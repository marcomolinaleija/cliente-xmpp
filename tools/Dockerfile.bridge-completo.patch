diff --git a/Dockerfile b/Dockerfile
index b7fb1ab..3d02a40 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -31,11 +31,18 @@ RUN uv venv $UV_PROJECT_ENVIRONMENT
 COPY pyproject.toml uv.lock build.py README.md .
 COPY slidge_whatsapp slidge_whatsapp
+COPY patches/patch_bridge_forwarding.py /tmp/patch_bridge_forwarding.py
+RUN python /tmp/patch_bridge_forwarding.py /tmp/unused /build \
+    --whatsapp-only --no-backup
 ARG SLIDGE_USE_LOCKFILE=
 RUN [ -z "$SLIDGE_USE_LOCKFILE" ] && rm uv.lock || true
 # install dependencies in /venv
 # .git/ needs to be mounted for setuptools-scm to set the version
 RUN --mount=source=.git,target=/build/.git,type=bind \
     uv sync --no-dev
+COPY patches/patch_slidge_whatsapp_mentions.py /tmp/patch_slidge_mentions.py
+RUN python /tmp/patch_slidge_mentions.py /venv/lib/python3.13/site-packages --no-backup && \
+    python /tmp/patch_bridge_forwarding.py /venv/lib/python3.13/site-packages \
+        --slidge-only --no-backup && \
+    uv pip install --python /venv/bin/python --no-cache --no-deps "rlottie-python==1.3.8"
 # (Optionnally) append .dev to the required slidge version in pyproject.toml,
 # invalidating the lockfile and setting the prerelease=allow policy for slidge.
 ARG SLIDGE_PRERELEASE=
